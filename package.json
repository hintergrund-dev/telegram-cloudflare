{
  "name": "@hintergrund/telegram-cloudflare",
  "version": "0.1.0",
  "description": "Telegram webhook helpers for Cloudflare Workers, designed to connect Telegram chats to serverless-pi.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "keywords": [
    "telegram",
    "cloudflare",
    "workers",
    "webhook",
    "serverless-pi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hintergrund-dev/telegram-cloudflare.git"
  },
  "bugs": {
    "url": "https://github.com/hintergrund-dev/telegram-cloudflare/issues"
  },
  "homepage": "https://github.com/hintergrund-dev/telegram-cloudflare#readme",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250614.0",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
